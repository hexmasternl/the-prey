<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.GamePage"
             Shell.NavBarIsVisible="False"
             Title="Operation">

    <VerticalStackLayout Spacing="18" Padding="28" VerticalOptions="Center">
        <Label Text="OPERATION ACTIVE" Style="{StaticResource TacticalTitle}" />
        <Label Text="SIGNAL LOCKED" Style="{StaticResource HudLabel}" />
        <Label Text="Active game landing — the live operation HUD lands here. (Coming soon.)"
               Style="{StaticResource TacticalBody}" />
    </VerticalStackLayout>

</ContentPage>
