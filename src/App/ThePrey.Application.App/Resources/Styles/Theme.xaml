<?xml version="1.0" encoding="UTF-8" ?>
<!--
    THE PREY — central design-system styles.
    Implements designs/the-prey-style-guide.html. All page visuals reference these
    styles/brushes; pages carry no inline styling of their own.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls">

    <!-- ===================== ATMOSPHERE BRUSHES ===================== -->

    <!-- Green phosphor halo that breathes behind the wordmark. -->
    <RadialGradientBrush x:Key="HaloBrush" Center="0.5,0.5" Radius="0.6">
        <GradientStop Color="#5964FF00" Offset="0.0" />
        <GradientStop Color="#1F64FF00" Offset="0.45" />
        <GradientStop Color="#0064FF00" Offset="1.0" />
    </RadialGradientBrush>

    <!-- Horizontal radar scan bar: dark edges with a bright signal core. -->
    <LinearGradientBrush x:Key="ScanlineBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0064FF00" Offset="0.0" />
        <GradientStop Color="#3364FF00" Offset="0.5" />
        <GradientStop Color="#0064FF00" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===================== PAGE ===================== -->

    <Style x:Key="PreyPage" TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Void}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="WelcomeRoot" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource Void}" />
    </Style>

    <!-- ===================== BACKDROP &amp; ANIMATED ACCENTS ===================== -->

    <!-- Full-bleed welcome-bg backdrop. -->
    <Style x:Key="BackdropImage" TargetType="Image">
        <Setter Property="Aspect" Value="AspectFill" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="InputTransparent" Value="True" />
    </Style>

    <!-- Rotating radar sweep overlay; pivots on the backdrop's radar centre. -->
    <Style x:Key="RadarSweep" TargetType="Image">
        <Setter Property="Aspect" Value="AspectFill" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="AnchorX" Value="0.5" />
        <Setter Property="AnchorY" Value="0.389" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- Soft pulsing halo behind the wordmark. -->
    <Style x:Key="TitleHalo" TargetType="shapes:Ellipse">
        <Setter Property="Fill" Value="{StaticResource HaloBrush}" />
        <Setter Property="WidthRequest" Value="340" />
        <Setter Property="HeightRequest" Value="340" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Thin scan bar travelling down the screen. -->
    <Style x:Key="Scanline" TargetType="BoxView">
        <Setter Property="Background" Value="{StaticResource ScanlineBrush}" />
        <Setter Property="HeightRequest" Value="2" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Start" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- ===================== TYPOGRAPHY ===================== -->

    <!-- Eyebrow: spaced uppercase PT Mono in dim signal. -->
    <Style x:Key="Eyebrow" TargetType="Label">
        <Setter Property="FontFamily" Value="PTMono" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource SignalDim}" />
        <Setter Property="CharacterSpacing" Value="4" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- Display wordmark: Special Elite, hero signal green with a glow. -->
    <Style x:Key="TitleDisplay" TargetType="Label">
        <Setter Property="FontFamily" Value="SpecialElite" />
        <Setter Property="FontSize" Value="64" />
        <Setter Property="TextColor" Value="{StaticResource Signal}" />
        <Setter Property="CharacterSpacing" Value="8" />
        <Setter Property="LineHeight" Value="0.95" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource SignalBrush}" Radius="22" Opacity="0.65" Offset="0,0" />
        </Setter>
    </Style>

    <!-- Signal accent divider under the wordmark. -->
    <Style x:Key="SignalDivider" TargetType="BoxView">
        <Setter Property="Color" Value="{StaticResource Signal}" />
        <Setter Property="HeightRequest" Value="2" />
        <Setter Property="WidthRequest" Value="64" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- Tagline / body copy: PT Mono, soft text. -->
    <Style x:Key="Tagline" TargetType="Label">
        <Setter Property="FontFamily" Value="PTMono" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextSoft}" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ===================== LAYOUT GROUPS ===================== -->

    <Style x:Key="WelcomeFooter" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="40" />
        <Setter Property="Padding" Value="32,0,32,56" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="End" />
    </Style>

    <Style x:Key="BrandStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="14" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="ActionStack" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="14" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- ===================== BUTTONS ===================== -->

    <!-- Primary: solid signal fill, void text, glow on press. One per screen. -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="FontFamily" Value="SpecialElite" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="BackgroundColor" Value="{StaticResource Signal}" />
        <Setter Property="TextColor" Value="{StaticResource Void}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="26,12" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource SignalBrush}" Radius="24" Opacity="0.55" Offset="0,0" />
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="TextColor" Value="{StaticResource TextGhost}" />
                            <Setter Property="BorderColor" Value="{StaticResource Line}" />
                            <Setter Property="BorderWidth" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Ghost: outlined signal, secondary action. -->
    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="FontFamily" Value="SpecialElite" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Signal}" />
        <Setter Property="BorderColor" Value="{StaticResource Signal}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Padding" Value="26,12" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#1464FF00" />
                            <Setter Property="Scale" Value="0.97" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TextGhost}" />
                            <Setter Property="BorderColor" Value="{StaticResource Line}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

</ResourceDictionary>
