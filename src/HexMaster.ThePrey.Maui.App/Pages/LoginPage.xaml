<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="Login">

    <Grid Padding="28" RowDefinitions="*, Auto, *">

        <Border Grid.Row="1" Style="{StaticResource HudPanel}"
                HorizontalOptions="Fill" VerticalOptions="Center">
            <VerticalStackLayout Spacing="22">
                <Image Source="theprey_logo.png"
                       HeightRequest="88"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       SemanticProperties.Description="The Prey logo" />

                <Label Text="ACCESS REQUIRED" Style="{StaticResource TacticalTitle}" />

                <Label Text="Authenticate to establish your signal and check for active operations."
                       Style="{StaticResource TacticalBody}" />

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       Style="{StaticResource AlertLabel}" />

                <Button Text="LOG IN"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalOptions="Fill" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />

                <Label Text="ESTABLISHING SIGNAL…"
                       IsVisible="{Binding IsBusy}"
                       Style="{StaticResource HudLabel}" />
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
