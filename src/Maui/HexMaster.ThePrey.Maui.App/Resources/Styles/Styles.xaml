    <!-- Head-start caption (uppercase, letter-spaced) above the countdown. -->
    <Style TargetType="Label" x:Key="GameHeadStartCaption" BasedOn="{StaticResource HudLabel}" />

    <!-- Move-early / 10-minute-penalty warning under the countdown — hunter red, centred. -->
    <Style TargetType="Label" x:Key="GamePenaltyWarning" BasedOn="{StaticResource AlertLabel}">
