<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HexMaster.ThePrey.Maui.App.Services.Localization"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.PreyGamePage"
             Shell.NavBarIsVisible="False"
             Title="{loc:Translate PreyGame_Title}">

    <Grid>
        <!-- Full-screen Mapsui MapControl is created and added here in code-behind. -->
        <Grid x:Name="MapHost" />

        <!-- Waiting-for-server overlay (game armed but not yet committed by the sweep). -->
        <Grid Style="{StaticResource GameOverlayScrim}" IsVisible="{Binding ShowWaitingOverlay}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="16">
                <Label Text="{loc:Translate PreyGame_Waiting_Title}" Style="{StaticResource GameOverlayTitle}" />
                <ActivityIndicator IsRunning="{Binding ShowWaitingOverlay}" HorizontalOptions="Center" />
                <Label Text="{loc:Translate PreyGame_Waiting_Body}" Style="{StaticResource GameOverlayBody}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Head-start overlay: non-blocking so the map stays pannable while the prey hides. -->
        <Grid Style="{StaticResource GameOverlayScrim}" IsVisible="{Binding ShowHeadStartOverlay}"
              InputTransparent="True">
            <VerticalStackLayout VerticalOptions="Center" Spacing="12">
                <Label Text="{loc:Translate PreyGame_HeadStart_Caption}" Style="{StaticResource GameHeadStartCaption}" />
                <Label Text="{Binding HeadStartCountdownText}" Style="{StaticResource GameCountdown}" />
                <Label Text="{loc:Translate PreyGame_HeadStart_Body}" Style="{StaticResource GameOverlayBody}" />
                <Label Text="{loc:Translate PreyGame_Penalty_Warning}" Style="{StaticResource GamePenaltyWarning}"
                       IsVisible="{Binding ShowPenaltyWarning}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Spectator indication (shown once tagged/out; the page stays connected until game-ended). -->
        <Label Text="{loc:Translate PreyGame_Spectator}" Style="{StaticResource GameSpectatorBanner}"
               IsVisible="{Binding Spectating}" VerticalOptions="Start" HorizontalOptions="Center"
               Margin="0,48,0,0" />

        <!-- Error region. -->
        <Grid Style="{StaticResource GameOverlayScrim}" IsVisible="{Binding HasError}">
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource GameErrorMessage}" VerticalOptions="Center" />
        </Grid>

        <!-- Busy indicator during the initial resolve. -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- Reserved prey HUD region (content owned by the separate prey-hud capability). -->
        <ContentView x:Name="HudRegion" VerticalOptions="Fill" InputTransparent="False" />
    </Grid>

</ContentPage>
