<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="ThePrey.Application.App.LandingPage"
             Style="{StaticResource PreyPage}"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="RootGrid" Style="{StaticResource WelcomeRoot}">

        <!-- Designed radar backdrop -->
        <Image Source="welcomebg.png" Style="{StaticResource BackdropImage}" />

        <!-- Animated radar sweep, pivoting on the backdrop's lock point -->
        <Image x:Name="SweepImage" Source="sweep.png" Style="{StaticResource RadarSweep}" />

        <!-- Scan bar travelling down the screen -->
        <BoxView x:Name="ScanLine" Style="{StaticResource Scanline}" />

        <!-- Foreground: wordmark + actions, anchored to the lower playfield -->
        <VerticalStackLayout Style="{StaticResource WelcomeFooter}">

            <Grid>
                <shapes:Ellipse x:Name="TitleHalo" Style="{StaticResource TitleHalo}" />

                <VerticalStackLayout Style="{StaticResource BrandStack}">
                    <Label x:Name="EyebrowLabel"
                           Text="OPERATIONS // FIELD ACTIVE"
                           Style="{StaticResource Eyebrow}" />

                    <Label x:Name="TitleLabel"
                           Text="THE PREY"
                           Style="{StaticResource TitleDisplay}" />

                    <BoxView x:Name="Divider" Style="{StaticResource SignalDivider}" />

                    <Label x:Name="CatchyPhraseLabel"
                           Style="{StaticResource Tagline}" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Style="{StaticResource ActionStack}">
                <Button x:Name="CreateAccountButton"
                        Style="{StaticResource BtnPrimary}"
                        Clicked="OnCreateAccountClicked" />

                <Button x:Name="LoginButton"
                        Style="{StaticResource BtnGhost}"
                        Clicked="OnLoginClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
