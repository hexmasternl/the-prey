<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThePrey.Application.App.GameStartPage"
             Style="{StaticResource PreyPage}">

    <Grid RowDefinitions="*,Auto" Padding="20,16,20,32">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Playfield -->
                <Label x:Name="PlayfieldLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />

                <Button x:Name="PlayfieldButton"
                        Style="{StaticResource BtnGhost}"
                        Margin="0,0,0,20"
                        Clicked="OnChoosePlayfieldClicked" />

                <!-- Game duration -->
                <Label x:Name="GameDurationLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />
                <HorizontalStackLayout x:Name="GameDurationOptions" Spacing="8" Margin="0,0,0,20" />

                <!-- Hunter delay -->
                <Label x:Name="HunterDelayLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />
                <HorizontalStackLayout x:Name="HunterDelayOptions" Spacing="8" Margin="0,0,0,20" />

                <!-- Final stage duration -->
                <Label x:Name="FinalStageLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />
                <HorizontalStackLayout x:Name="FinalStageOptions" Spacing="8" Margin="0,0,0,20" />

                <!-- Default location interval -->
                <Label x:Name="DefaultIntervalLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />
                <HorizontalStackLayout x:Name="DefaultIntervalOptions" Spacing="8" Margin="0,0,0,20" />

                <!-- Final location interval -->
                <Label x:Name="FinalIntervalLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       Margin="0,0,0,6" />
                <HorizontalStackLayout x:Name="FinalIntervalOptions" Spacing="8" Margin="0,0,0,20" />

                <!-- Prey boundary penalty -->
                <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                    <Label x:Name="PreyPenaltyLabel"
                           Grid.Column="0"
                           FontFamily="PTMono"
                           FontSize="11"
                           CharacterSpacing="2"
                           TextColor="{StaticResource SignalDim}"
                           VerticalOptions="Center" />
                    <Switch x:Name="PreyPenaltySwitch"
                            Grid.Column="1"
                            OnColor="{StaticResource Signal}"
                            ThumbColor="{StaticResource Void}"
                            IsToggled="True" />
                </Grid>

                <!-- Hunter boundary penalty -->
                <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                    <Label x:Name="HunterPenaltyLabel"
                           Grid.Column="0"
                           FontFamily="PTMono"
                           FontSize="11"
                           CharacterSpacing="2"
                           TextColor="{StaticResource SignalDim}"
                           VerticalOptions="Center" />
                    <Switch x:Name="HunterPenaltySwitch"
                            Grid.Column="1"
                            OnColor="{StaticResource Signal}"
                            ThumbColor="{StaticResource Void}"
                            IsToggled="True" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Spacing="8" Margin="0,12,0,0">
            <ActivityIndicator x:Name="BusyIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="{StaticResource Signal}" />
            <Button x:Name="CreateButton"
                    Style="{StaticResource BtnPrimary}"
                    IsEnabled="False"
                    Clicked="OnCreateClicked" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
