        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray500}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="15" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Brush" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
        <Setter Property="Offset" Value="10,10" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                            <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="ThumbColor" Value="{StaticResource White}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="On">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray200}}" />
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>
  
    <!--
    <Style TargetType="TitleBar">
        <Setter Property="MinimumHeightRequest" Value="32"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="TitleActiveStates">
                    <VisualState x:Name="TitleBarTitleActive">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="ForegroundColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="TitleBarTitleInactive">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
                            <Setter Property="ForegroundColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>
    -->

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgBase}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource TpBgBase}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TpSignal}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TpText}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource TpTextGhost}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource TpSignal}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource TpSignal}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TpTextSoft}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource White}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource White}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}" />
    </Style>

    <!-- ============================================================= -->
    <!-- In-game HUD — bottom-anchored translucent overlay, its metrics, -->
    <!-- countdown bars, collapse button, and the Center/Tag icon buttons.-->
    <!-- All reuse the Tp* tokens; the HUD view carries no visual literals.-->
    <!-- ============================================================= -->

    <!-- Dark, semi-transparent panel anchored to the bottom of the game view. -->
    <Style TargetType="Border" x:Key="HudOverlayPanel">
        <Setter Property="BackgroundColor" Value="{StaticResource TpHudPanel}" />
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14,14,0,0" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="VerticalOptions" Value="End" />
    </Style>

    <!-- Alarming boundary-penalty banner, pinned to the top of the game view while the local player is
         penalised. Full-bleed hunter red with rounded bottom corners so it reads as a hazard bar dropped
         from the top edge. Reuses the established danger token (TpHunter) rather than a new colour. -->
    <Style TargetType="Border" x:Key="HudPenaltyBanner">
        <Setter Property="BackgroundColor" Value="{StaticResource TpHunter}" />
        <Setter Property="Stroke" Value="{StaticResource TpHunterBrush}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 0,0,14,14" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Start" />
    </Style>

    <!-- "PENALTY" caption inside the banner — uppercase, letter-spaced, light on red. -->
    <Style TargetType="Label" x:Key="HudPenaltyCaption">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="4" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Remaining-penalty mm:ss countdown beneath the caption. -->
    <Style TargetType="Label" x:Key="HudPenaltyCountdown" BasedOn="{StaticResource HudPenaltyCaption}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- Large signal-green metric value (game clock, preys, distance). -->
    <Style TargetType="Label" x:Key="HudMetricValue">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Small dim caption beneath each metric (reuses the shared HudLabel). -->
    <Style TargetType="Label" x:Key="HudMetricCaption" BasedOn="{StaticResource HudLabel}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- Collapsed-state big clock readout. -->
    <Style TargetType="Label" x:Key="HudClock" BasedOn="{StaticResource HudMetricValue}">
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!-- Next-ping label above the shrinking bar. -->
    <Style TargetType="Label" x:Key="HudPingCaption" BasedOn="{StaticResource HudLabel}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <!-- Signal-green next-ping progress bar. -->
    <Style TargetType="ProgressBar" x:Key="HudProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource TpSignal}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpSignalDeep}" />
    </Style>

    <!-- Full-width collapse button. -->
    <Style TargetType="Button" x:Key="HudCollapseButton">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface2}" />
        <Setter Property="BorderColor" Value="{StaticResource TpLine}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- Right-aligned square icon button above the HUD (Center default / inactive). A Border hosting a
         vector Path rather than a Button: MAUI's Button renders text or a raster ImageSource only, so
         drawing the glyph as a Path is what keeps every colour a Colors.xaml token (an image asset would
         bake its own hex) and lets a state change recolour the glyph itself. -->
    <Style TargetType="Border" x:Key="HudIconButton">
        <Setter Property="BackgroundColor" Value="{StaticResource TpHudPanel}" />
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Center toggle: dim when free-panning, signal green while following the device location. -->
    <Style TargetType="Border" x:Key="HudCenterButton" BasedOn="{StaticResource HudIconButton}">
        <Style.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsFollowingLocation}" Value="True">
                <Setter Property="Stroke" Value="{StaticResource TpSignalBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Hunter-only Tag button — hunter red accent. -->
    <Style TargetType="Border" x:Key="HudTagButton" BasedOn="{StaticResource HudIconButton}">
        <Setter Property="Stroke" Value="{StaticResource TpHunterBrush}" />
    </Style>

    <!-- Shared geometry of the HUD button glyphs; drawn on a 24x24 canvas. -->
    <Style TargetType="Path" x:Key="HudIconGlyph">
        <Setter Property="Aspect" Value="Uniform" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- Center glyph: the navigation arrow, filled. Dim while free-panning, signal green while following. -->
    <Style TargetType="Path" x:Key="HudCenterGlyph" BasedOn="{StaticResource HudIconGlyph}">
        <Setter Property="Data" Value="M12 2 L21 21 L12 16.5 L3 21 Z" />
        <Setter Property="Fill" Value="{StaticResource TpTextSoftBrush}" />
        <Style.Triggers>
            <DataTrigger TargetType="Path" Binding="{Binding IsFollowingLocation}" Value="True">
                <Setter Property="Fill" Value="{StaticResource TpSignalBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Tag glyph: a reticle locked on the prey — four ticks around an open circle, hunter red. -->
    <Style TargetType="Path" x:Key="HudTagGlyph" BasedOn="{StaticResource HudIconGlyph}">
        <Setter Property="Data" Value="M12 1 L12 5 M12 19 L12 23 M1 12 L5 12 M19 12 L23 12 M12 7 A5 5 0 1 0 12 17 A5 5 0 1 0 12 7 Z" />
        <Setter Property="Stroke" Value="{StaticResource TpHunterBrush}" />
        <Setter Property="StrokeThickness" Value="2" />
    </Style>

    <!-- Transient HUD status/feedback line (info = dim, error = hunter red via trigger). -->
    <Style TargetType="Label" x:Key="HudStatusMessage">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding StatusIsError}" Value="True">
                <Setter Property="TextColor" Value="{StaticResource TpHunter}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Tag-candidate row title/subtitle in the selection modal. -->
    <Style TargetType="Label" x:Key="TagCandidateCallsign">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CharacterSpacing" Value="1" />
    </Style>

    <Style TargetType="Label" x:Key="TagCandidateDistance" BasedOn="{StaticResource HudLabel}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

    <!-- ============================================================= -->
    <!-- Post-game outcome screen. The page composes structure only and -->
    <!-- picks the victory or defeat variant of each style from the     -->
    <!-- view model's resolved result.                                  -->
    <!-- ============================================================= -->

    <!-- Full-bleed void backdrop; the outcome is terminal, so nothing shows through it. -->
    <Style TargetType="Grid" x:Key="OutcomeContainer">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="Padding" Value="32,64" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
    </Style>

    <!-- Centred stack holding the badge, headline, winning side, reason and survivor count. -->
    <Style TargetType="VerticalStackLayout" x:Key="OutcomeStack">
        <Setter Property="Spacing" Value="18" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- Halo disc behind the headline — a soft wash in the result's color. -->
    <Style TargetType="Border" x:Key="OutcomeBadgeBase">
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="WidthRequest" Value="132" />
        <Setter Property="HeightRequest" Value="132" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="StrokeShape" Value="RoundRectangle 66" />
    </Style>

    <Style TargetType="Border" x:Key="OutcomeBadgeVictory" BasedOn="{StaticResource OutcomeBadgeBase}">
        <Setter Property="Stroke" Value="{StaticResource TpVictoryBrush}" />
        <Setter Property="Background" Value="{StaticResource TpVictoryHaloBrush}" />
    </Style>

    <Style TargetType="Border" x:Key="OutcomeBadgeDefeat" BasedOn="{StaticResource OutcomeBadgeBase}">
        <Setter Property="Stroke" Value="{StaticResource TpDefeatBrush}" />
        <Setter Property="Background" Value="{StaticResource TpDefeatHaloBrush}" />
    </Style>

    <!-- The glyph inside the badge (a check for a win, a cross for a loss). -->
    <Style TargetType="Label" x:Key="OutcomeBadgeGlyphBase">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="FontSize" Value="56" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="OutcomeBadgeGlyphVictory" BasedOn="{StaticResource OutcomeBadgeGlyphBase}">
        <Setter Property="TextColor" Value="{StaticResource TpVictory}" />
    </Style>

    <Style TargetType="Label" x:Key="OutcomeBadgeGlyphDefeat" BasedOn="{StaticResource OutcomeBadgeGlyphBase}">
        <Setter Property="TextColor" Value="{StaticResource TpDefeat}" />
    </Style>

    <!-- VICTORY / DEFEAT / GAME OVER headline — oversized display face in the result's color. -->
    <Style TargetType="Label" x:Key="OutcomeHeadlineBase" BasedOn="{StaticResource TacticalTitle}">
        <Setter Property="FontSize" Value="52" />
        <Setter Property="CharacterSpacing" Value="8" />
    </Style>

    <Style TargetType="Label" x:Key="OutcomeHeadlineVictory" BasedOn="{StaticResource OutcomeHeadlineBase}">
        <Setter Property="TextColor" Value="{StaticResource TpVictory}" />
    </Style>

    <Style TargetType="Label" x:Key="OutcomeHeadlineDefeat" BasedOn="{StaticResource OutcomeHeadlineBase}">
        <Setter Property="TextColor" Value="{StaticResource TpDefeat}" />
    </Style>

    <!-- Neutral headline for the state where the final record could not be read. -->
    <Style TargetType="Label" x:Key="OutcomeHeadlineNeutral" BasedOn="{StaticResource OutcomeHeadlineBase}">
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
    </Style>

    <!-- "THE HUNTER WINS" / "THE PREY WIN" — the winning side, regardless of the local result. -->
    <Style TargetType="Label" x:Key="OutcomeWinningSide" BasedOn="{StaticResource StatusLabel}">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="CharacterSpacing" Value="5" />
    </Style>

    <!-- Why the game ended. -->
    <Style TargetType="Label" x:Key="OutcomeReason" BasedOn="{StaticResource TacticalBody}">
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Escapee count, shown to both sides whenever the preys took it. -->
    <Style TargetType="Label" x:Key="OutcomeSurvivors" BasedOn="{StaticResource HudLabel}">
        <Setter Property="TextColor" Value="{StaticResource TpCaution}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Debriefing spinner caption while the final record is read. -->
    <Style TargetType="Label" x:Key="OutcomeBusyCaption" BasedOn="{StaticResource HudLabel}" />

    <!-- The single terminal action: back to the main menu. -->
    <Style TargetType="Button" x:Key="OutcomeCloseButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="End" />
    </Style>

</ResourceDictionary>
