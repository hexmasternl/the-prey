<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HexMaster.ThePrey.Maui.App.Services.Localization"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.GamePage"
             Shell.NavBarIsVisible="False"
             Title="Operation">

    <VerticalStackLayout Spacing="18" Padding="28" VerticalOptions="Center">
        <Label Text="{loc:Translate Game_Title}" Style="{StaticResource TacticalTitle}" />
        <Label Text="{loc:Translate Game_Subtitle}" Style="{StaticResource HudLabel}" />
        <Label Text="{loc:Translate Game_Body}"
               Style="{StaticResource TacticalBody}" />
    </VerticalStackLayout>

</ContentPage>
