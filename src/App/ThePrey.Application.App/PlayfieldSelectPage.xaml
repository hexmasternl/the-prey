<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ThePrey.Application.App"
             x:Class="ThePrey.Application.App.PlayfieldSelectPage"
             Style="{StaticResource PreyPage}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Search -->
        <Entry x:Name="SearchEntry"
               Grid.Row="0"
               TextChanged="OnSearchTextChanged"
               FontFamily="PTMono"
               FontSize="14"
               TextColor="{StaticResource TextPrimary}"
               BackgroundColor="{StaticResource Surface}"
               PlaceholderColor="{StaticResource TextGhost}"
               Margin="20,14,20,8" />

        <!-- Results / states layer -->
        <Grid Grid.Row="1">

            <ActivityIndicator x:Name="SearchLoadingIndicator"
                               Style="{StaticResource PreySpinner}"
                               IsRunning="False"
                               IsVisible="False"
                               VerticalOptions="Center" />

            <Label x:Name="EmptyStateLabel"
                   IsVisible="False"
                   FontFamily="PTMono"
                   FontSize="14"
                   TextColor="{StaticResource TextSoft}"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center"
                   Margin="32,0" />

            <CollectionView x:Name="PlayfieldsList"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:PlayfieldSelectItem">
                        <Grid BackgroundColor="{Binding RowColor}"
                              Padding="20,14"
                              Margin="0,0,0,1"
                              RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlayfieldTapped" />
                            </Grid.GestureRecognizers>

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontFamily="PTMono"
                                   FontSize="14"
                                   TextColor="{Binding NameColor}"
                                   VerticalOptions="Center" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Subtitle}"
                                   IsVisible="{Binding HasSubtitle}"
                                   FontFamily="PTMono"
                                   FontSize="11"
                                   TextColor="{Binding SubtitleColor}" />

                            <Label Grid.Row="0" Grid.Column="1"
                                   Grid.RowSpan="2"
                                   Text="{Binding Marker}"
                                   FontFamily="PTMono"
                                   FontSize="12"
                                   TextColor="{StaticResource Signal}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- Select -->
        <Button x:Name="SelectButton"
                Grid.Row="2"
                Style="{StaticResource BtnPrimary}"
                IsEnabled="False"
                Margin="20,12,20,32"
                Clicked="OnSelectClicked" />

        <!-- Toast (non-blocking hints: not-synced row, search failure) -->
        <Border x:Name="ToastBorder"
                Grid.RowSpan="3"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="24,0,24,100"
                BackgroundColor="{StaticResource Hunter}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 6"
                Padding="16,10"
                IsVisible="False"
                InputTransparent="True">
            <Label x:Name="ToastLabel"
                   FontFamily="PTMono"
                   FontSize="13"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center" />
        </Border>

    </Grid>

</ContentPage>
