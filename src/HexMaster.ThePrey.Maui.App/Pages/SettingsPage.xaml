<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="Settings">

    <VerticalStackLayout Spacing="18" Padding="28" VerticalOptions="Center">
        <Label Text="SETTINGS" Style="{StaticResource TacticalTitle}" />
        <Label Text="SYSTEM CONFIG" Style="{StaticResource HudLabel}" />
        <Label Text="Adjust app and operative settings. (Coming soon.)"
               Style="{StaticResource TacticalBody}" />
    </VerticalStackLayout>

</ContentPage>
