<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HexMaster.ThePrey.Maui.App.Services.Localization"
             xmlns:pages="clr-namespace:HexMaster.ThePrey.Maui.App.Pages"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.TagCandidatesPage"
             BackgroundColor="{StaticResource TpBgBase}"
             Title="{loc:Translate Tag_DialogTitle}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="16">
        <Label Grid.Row="0"
               Style="{StaticResource TacticalTitle}"
               Text="{loc:Translate Tag_DialogTitle}" />

        <CollectionView Grid.Row="1"
                        x:Name="CandidatesList"
                        SelectionMode="Single"
                        SelectionChanged="OnCandidateSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="pages:TagCandidateRow">
                    <Grid ColumnDefinitions="*,Auto" Padding="8,14">
                        <Label Grid.Column="0"
                               Style="{StaticResource TagCandidateCallsign}"
                               Text="{Binding Callsign}" />
                        <Label Grid.Column="1"
                               Style="{StaticResource TagCandidateDistance}"
                               Text="{Binding Distance}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Style="{StaticResource HudCollapseButton}"
                Text="{loc:Translate Tag_Cancel}"
                Clicked="OnCancelClicked" />
    </Grid>
</ContentPage>
