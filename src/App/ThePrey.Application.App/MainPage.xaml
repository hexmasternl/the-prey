<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThePrey.Application.App.MainPage"
             Style="{StaticResource PreyPage}"
             Shell.NavBarIsVisible="False">

    <Grid Style="{StaticResource WelcomeRoot}">

        <!-- Shared radar backdrop -->
        <Image Source="welcomebg.png" Style="{StaticResource BackdropImage}" />

        <VerticalStackLayout Style="{StaticResource WelcomeFooter}">

            <VerticalStackLayout Style="{StaticResource BrandStack}">
                <Label Text="MAIN MENU" Style="{StaticResource Eyebrow}" />
                <Label x:Name="TitleLabel" Style="{StaticResource TitleDisplay}" />
                <BoxView Style="{StaticResource SignalDivider}" />
            </VerticalStackLayout>

            <VerticalStackLayout Style="{StaticResource MenuStack}">
                <Button x:Name="PlayButton"
                        Style="{StaticResource BtnPrimary}"
                        Clicked="OnPlayClicked" />

                <Button x:Name="PlayfieldsButton"
                        Style="{StaticResource BtnGhost}"
                        Clicked="OnPlayfieldsClicked" />

                <Button x:Name="FriendsButton"
                        Style="{StaticResource BtnGhost}"
                        IsEnabled="False" />

                <Button x:Name="QuitButton"
                        Style="{StaticResource BtnGhost}"
                        Clicked="OnQuitClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
