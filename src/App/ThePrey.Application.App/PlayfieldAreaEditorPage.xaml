<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="ThePrey.Application.App.PlayfieldAreaEditorPage"
             Style="{StaticResource PreyPage}"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Full-screen Mapsui map -->
        <mapsui:MapControl x:Name="MapControl" />

        <!-- Floating Cancel / OK buttons overlaid at the top -->
        <Grid VerticalOptions="Start"
              HorizontalOptions="Fill"
              Padding="20,52,20,0"
              ColumnDefinitions="*,16,*">

            <Button x:Name="CancelButton"
                    Grid.Column="0"
                    Style="{StaticResource BtnGhost}"
                    Clicked="OnCancelClicked" />

            <Button x:Name="OkButton"
                    Grid.Column="2"
                    Style="{StaticResource BtnPrimary}"
                    IsEnabled="False"
                    Clicked="OnOkClicked" />

        </Grid>

    </Grid>

</ContentPage>
