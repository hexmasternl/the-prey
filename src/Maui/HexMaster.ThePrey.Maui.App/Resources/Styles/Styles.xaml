    <Style TargetType="Label" x:Key="GameOverlayTitle" BasedOn="{StaticResource TacticalTitle}" />

    <!-- Overlay descriptive body under the heading. -->
    <Style TargetType="Label" x:Key="GameOverlayBody" BasedOn="{StaticResource TacticalBody}" />

    <!-- Oversized mm:ss head-start countdown readout (display face, signal green). -->
    <Style TargetType="Label" x:Key="GameCountdown" BasedOn="{StaticResource TacticalTitle}">
