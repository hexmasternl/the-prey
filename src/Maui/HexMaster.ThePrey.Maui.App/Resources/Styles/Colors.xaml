<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- ============================================================= -->
    <!-- The Prey tactical phosphor-green design tokens (tp-* family).  -->
    <!-- Mirrors src/ThePrey/src/theme/variables.scss. The ONLY place   -->
    <!-- these colors are defined; reference them by key everywhere.    -->
    <!-- ============================================================= -->
    <Color x:Key="TpBgVoid">#0c0e0c</Color>
    <Color x:Key="TpBgBase">#181b17</Color>
    <Color x:Key="TpBgSurface">#23271f</Color>
    <Color x:Key="TpBgSurface2">#2d3328</Color>
    <Color x:Key="TpLine">#39402f</Color>
    <Color x:Key="TpLineSoft">#2a2f24</Color>
    <Color x:Key="TpSignal">#64ff00</Color>
    <Color x:Key="TpSignalDim">#3f9e00</Color>
    <Color x:Key="TpSignalDeep">#1f4d00</Color>
    <Color x:Key="TpHunter">#ff2f1f</Color>
    <Color x:Key="TpHunterDim">#a01408</Color>
    <Color x:Key="TpCaution">#ffb300</Color>
    <Color x:Key="TpInfo">#13e0c8</Color>
    <Color x:Key="TpText">#dcf6d2</Color>
    <Color x:Key="TpTextSoft">#8c9a83</Color>
    <Color x:Key="TpTextGhost">#5a6553</Color>

    <SolidColorBrush x:Key="TpBgVoidBrush" Color="{StaticResource TpBgVoid}"/>
    <SolidColorBrush x:Key="TpBgBaseBrush" Color="{StaticResource TpBgBase}"/>
    <SolidColorBrush x:Key="TpBgSurfaceBrush" Color="{StaticResource TpBgSurface}"/>
    <SolidColorBrush x:Key="TpLineBrush" Color="{StaticResource TpLine}"/>
    <SolidColorBrush x:Key="TpSignalBrush" Color="{StaticResource TpSignal}"/>
    <SolidColorBrush x:Key="TpHunterBrush" Color="{StaticResource TpHunter}"/>
    <SolidColorBrush x:Key="TpCautionBrush" Color="{StaticResource TpCaution}"/>

    <!-- Dark, semi-transparent scrim for the in-game HUD overlay so the map shows through. -->
    <Color x:Key="TpHudPanel">#D2181B17</Color>
    <SolidColorBrush x:Key="TpHudPanelBrush" Color="{StaticResource TpHudPanel}"/>
    <Color x:Key="TpSignalDeepColor">#1f4d00</Color>
    <SolidColorBrush x:Key="TpBgSurface2Brush" Color="{StaticResource TpBgSurface2}"/>
    <SolidColorBrush x:Key="TpTextBrush" Color="{StaticResource TpText}"/>

    <!-- Gameplay map "caught / out" marker: a muted grey-green for tagged preys. The other map
         marker colors reuse TpSignal (green self/other-prey) and TpHunter (red hunter/prey); the
         GameMapPalette C# class derives all Mapsui feature colors from these central tokens. -->
    <Color x:Key="TpCaught">#6b7267</Color>
    <SolidColorBrush x:Key="TpCaughtBrush" Color="{StaticResource TpCaught}"/>

    <!-- Green scan-beam glow for the Join screen's laser sweep: a bright signal-green core that fades to
         fully transparent at the band edges. Alpha-graded variants of TpSignal, used only in the
         JoinLaserSweep gradient. -->
    <Color x:Key="TpSignalBeam">#CC64FF00</Color>
    <Color x:Key="TpSignalBeamEdge">#0064FF00</Color>

    <!-- Post-game outcome treatment. Victory reads as the signal-green success axis, defeat as the
         hunter-red failure axis — the same two poles the rest of the game uses, named semantically so
         the outcome page never reaches for a role color directly. The Halo variants are the low-alpha
         wash behind the headline badge. -->
    <Color x:Key="TpVictory">#64ff00</Color>
    <Color x:Key="TpVictoryHalo">#2664FF00</Color>
    <Color x:Key="TpDefeat">#ff2f1f</Color>
    <Color x:Key="TpDefeatHalo">#26FF2F1F</Color>

    <SolidColorBrush x:Key="TpVictoryBrush" Color="{StaticResource TpVictory}"/>
    <SolidColorBrush x:Key="TpVictoryHaloBrush" Color="{StaticResource TpVictoryHalo}"/>
    <SolidColorBrush x:Key="TpDefeatBrush" Color="{StaticResource TpDefeat}"/>
    <SolidColorBrush x:Key="TpDefeatHaloBrush" Color="{StaticResource TpDefeatHalo}"/>
</ResourceDictionary>