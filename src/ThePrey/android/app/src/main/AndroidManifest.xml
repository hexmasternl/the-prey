<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Custom-scheme deep link. Routes nl.hexmaster.theprey://... URIs back into
                the app, which is what makes the Auth0 redirect callback (and game-join
                links) reach AppComponent's appUrlOpen / getLaunchUrl handlers. Without
                this filter the OS has no registered handler for the scheme and silently
                drops the redirect, so login never completes on-device.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/custom_url_scheme" />
            </intent-filter>

            <!--
                Android App Link for game-join URLs. autoVerify makes the OS fetch
                https://theprey.nl/.well-known/assetlinks.json and, once the signing
                fingerprint matches, route https://theprey.nl/games/join/<id> (and the
                www host) straight into the app instead of the browser. Scoped to the
                /games/join path so documentation pages on the same domain are NOT
                captured by the app.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="theprey.nl" />
                <data android:host="www.theprey.nl" />
                <data android:pathPrefix="/games/join" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
            Background location tracking is handled by the
            @capacitor-community/background-geolocation plugin, which contributes its own
            foreground service (foregroundServiceType="location") via manifest merge.
        -->

    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- GPS / location -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Required to track location while the app is backgrounded / screen-locked -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ (API 34): must declare the service type explicitly -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Android 13+ (API 33): required to display the foreground-service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

</manifest>
