<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HexMaster.ThePrey.Maui.App.Services.Localization"
             x:Class="HexMaster.ThePrey.Maui.App.Controls.PasscodeEntry"
             x:Name="Root">

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnTapped" />
    </ContentView.GestureRecognizers>

    <!-- A single hidden Entry captures all keyboard/paste input; the digit boxes below it are
         rebuilt from code-behind (one Border+Label per Length) and reflect the entry's value. -->
    <Grid HorizontalOptions="Center">

        <HorizontalStackLayout x:Name="BoxRow" Style="{StaticResource PasscodeBoxRow}" />

        <Entry x:Name="HiddenEntry"
               Style="{StaticResource PasscodeHiddenEntry}"
               TextChanged="OnHiddenEntryTextChanged"
               SemanticProperties.Description="{loc:Translate Passcode_AccessibilityLabel}" />

    </Grid>

</ContentView>
