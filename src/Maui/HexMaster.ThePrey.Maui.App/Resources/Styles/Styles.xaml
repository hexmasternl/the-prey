<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================= -->
    <!-- The Prey — tactical typography + component styles.             -->
    <!-- Pages carry NO local styling: consume these by key or          -->
    <!-- implicitly. Monospace faces fall back to the platform system   -->
    <!-- monospace; drop SpecialElite/PTMono TTFs in Resources\Fonts    -->
    <!-- and swap the two Value strings below to upgrade.               -->
    <!-- ============================================================= -->
    <!-- Tactical body/readout monospace face. Registered in MauiProgram from
         Resources\Fonts\PTMono-Regular.ttf. Used for HUD labels, status readouts, body copy. -->
    <x:String x:Key="TpBodyFont">PTMono</x:String>
    <!-- Tactical display face (typewriter/stencil). Registered in MauiProgram from
         Resources\Fonts\SpecialElite-Regular.ttf. Used for headings and the wordmark. -->
    <x:String x:Key="TpDisplayFont">SpecialElite</x:String>

    <!-- Display title / numeric readouts -->
    <Style TargetType="Label" x:Key="TacticalTitle">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="CharacterSpacing" Value="4" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Uppercase, letter-spaced HUD label -->
    <Style TargetType="Label" x:Key="HudLabel">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Live status readout (signal green) -->
    <Style TargetType="Label" x:Key="StatusLabel">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Oversized two-word slogan line (display face). The line's default words use
         TpText; the accent word carries SloganAccent. Spans inherit the font from here. -->
    <Style TargetType="Label" x:Key="SloganLine">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="46" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Leading (default-color) word of a slogan line. -->
    <Style TargetType="Span" x:Key="SloganWord">
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
    </Style>

    <!-- Accent word of a slogan line (signal green). -->
    <Style TargetType="Span" x:Key="SloganAccent">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>

    <!-- Dim descriptive tagline under the slogan (PT Mono body face). -->
    <Style TargetType="Label" x:Key="SloganDescription">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Body copy -->
    <Style TargetType="Label" x:Key="TacticalBody">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Amber alert / error banner text -->
    <Style TargetType="Label" x:Key="AlertLabel">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpCaution}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Primary tactical call-to-action button (filled signal green) -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpSignal}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource TpSignalDeep}" />
                            <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Decorative corner-bracket segment (signal green hairline) -->
    <Style TargetType="BoxView" x:Key="CornerBracket">
        <Setter Property="Color" Value="{StaticResource TpSignal}" />
    </Style>

    <!-- Framed HUD panel (surface fill, hairline border) -->
    <Style TargetType="Border" x:Key="HudPanel">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="Padding" Value="28,36" />
    </Style>

    <!-- Soft signal glow for hero elements. Shadow has no Style property, so this is a shared
         Shadow object referenced directly via the element's Shadow property. -->
    <Shadow x:Key="SignalGlow"
            Brush="{StaticResource TpSignalBrush}"
            Radius="18"
            Opacity="0.6"
            Offset="0,0" />

    <!-- Void-black splash base — matches the native OS splash Color (#0c0e0c) so the
         hand-off to the running app shows no color flash. Sits behind the map layer. -->
    <Style TargetType="BoxView" x:Key="SplashBase">
        <Setter Property="Color" Value="{StaticResource TpBgVoid}" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
    </Style>

    <!-- Full-bleed tactical operations-grid map behind the launch/splash content.
         Dimmed so foreground readouts stay legible; transparent to input so it
         never intercepts touches. -->
    <Style TargetType="Image" x:Key="SplashMapBackground">
        <Setter Property="Aspect" Value="AspectFill" />
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
    </Style>

    <!-- Enlarged brand mark for the splash hero, with the shared signal glow. -->
    <Style TargetType="Image" x:Key="SplashLogo">
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter Property="HeightRequest" Value="220" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Shadow" Value="{StaticResource SignalGlow}" />
    </Style>

    <!-- ============================================================= -->
    <!-- Main menu — button variants, HUD readout, left-aligned hero.   -->
    <!-- ============================================================= -->

    <!-- Filled hunter-red call-to-action (Resume Game). -->
    <Style TargetType="Button" x:Key="HunterButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource TpHunter}" />
        <Setter Property="TextColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource TpHunterDim}" />
                            <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Outline call-to-action — void base, signal-green border + text (secondary actions). -->
    <Style TargetType="Button" x:Key="OutlineButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
        <Setter Property="BorderColor" Value="{StaticResource TpSignal}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource TpBgVoid}" />
                            <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
                            <Setter Property="BorderColor" Value="{StaticResource TpSignalDeep}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Oversized, dimmed tactical map that slowly pans behind the menu. Scaled >1 so the pan
         reveals map rather than empty edges; transparent to input so buttons still receive taps. -->
    <Style TargetType="Image" x:Key="MenuMapBackground">
        <Setter Property="Aspect" Value="AspectFill" />
        <Setter Property="Opacity" Value="0.35" />
        <Setter Property="Scale" Value="1.35" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
    </Style>

    <!-- Small dim right-aligned telemetry line (GPS position, app version). -->
    <Style TargetType="Label" x:Key="HudReadout">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

    <!-- Left-aligned app title for the main-menu header (BasedOn the centered TacticalTitle). -->
    <Style TargetType="Label" x:Key="MenuTitle" BasedOn="{StaticResource TacticalTitle}">
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <!-- Left-aligned hero slogan line (BasedOn the centered splash SloganLine). Its words reuse
         SloganWord (default) and SloganAccent (signal green). -->
    <Style TargetType="Label" x:Key="MenuSloganLine" BasedOn="{StaticResource SloganLine}">
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <!-- Left-aligned dim tagline under the hero slogan (BasedOn the centered SloganDescription). -->
    <Style TargetType="Label" x:Key="MenuTagline" BasedOn="{StaticResource SloganDescription}">
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <!-- Landscape hero slogan: the two clauses joined onto ONE line. Smaller than the stacked
         portrait slogan so all 24 characters stay on a single line on phone-width landscapes;
         NoWrap guarantees it never spills to a second line. -->
    <Style TargetType="Label" x:Key="MenuSloganLineWide" BasedOn="{StaticResource MenuSloganLine}">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <!-- Very small signed-in player byline under the menu (display face, regular text color). Its
         per-character spans carry their own color so the code-behind can sweep a signal-green
         running light across them; the base/lit tokens are TpText and TpSignal from Colors.xaml. -->
    <Style TargetType="Label" x:Key="MenuPlayerName">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <!-- Dim resting color so the code-behind's bright signal-green running light stands out. -->
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- ============================================================= -->
    <!-- Settings — form-field, language-toggle, and status/hint styles.-->
    <!-- All reuse the Tp* tokens; no page carries these literals.       -->
    <!-- ============================================================= -->

    <!-- Uppercase, letter-spaced field label (left-aligned). -->
    <Style TargetType="Label" x:Key="SettingsFieldLabel">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <!-- Framed, filled entry for the display-name field. -->
    <Style TargetType="Entry" x:Key="SettingsEntry">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TpTextGhost}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="52" />
    </Style>

    <!-- Small saving/saved/error hint under a field. Base + colored variants. -->
    <Style TargetType="Label" x:Key="SettingsStatusHint">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <Style TargetType="Label" x:Key="SettingsStatusSaving" BasedOn="{StaticResource SettingsStatusHint}">
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
    </Style>

    <Style TargetType="Label" x:Key="SettingsStatusSaved" BasedOn="{StaticResource SettingsStatusHint}">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>

    <Style TargetType="Label" x:Key="SettingsStatusError" BasedOn="{StaticResource SettingsStatusHint}">
        <Setter Property="TextColor" Value="{StaticResource TpCaution}" />
    </Style>

    <!-- Two-state EN/NL language toggle (Switch): off = EN, on = NL. -->
    <Style TargetType="Switch" x:Key="LanguageToggle">
        <Setter Property="OnColor" Value="{StaticResource TpSignal}" />
        <Setter Property="ThumbColor" Value="{StaticResource TpText}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- EN / NL labels flanking the toggle (display face). -->
    <Style TargetType="Label" x:Key="LanguageSegmentLabel">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- ============================================================= -->
    <!-- Playfields list — tab header, list items, badges, search.      -->
    <!-- Active/inactive tab styling and badge colors come from here;   -->
    <!-- the page carries no literals. All reuse the Tp* tokens.        -->
    <!-- ============================================================= -->

    <!-- Segmented tab-header button, inactive (dim) base look. -->
    <Style TargetType="Button" x:Key="TabButton">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="BorderColor" Value="{StaticResource TpLine}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CharacterSpacing" Value="3" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>

    <!-- Active (signal-green) tab look, layered over TabButton via a data trigger. Kept as its own
         key so the page never sets active/inactive colors inline; the two segment styles below apply
         it when their bound selection flag is true. -->
    <Style TargetType="Button" x:Key="TabButtonActive" BasedOn="{StaticResource TabButton}">
        <Setter Property="TextColor" Value="{StaticResource TpBgVoid}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpSignal}" />
        <Setter Property="BorderColor" Value="{StaticResource TpSignal}" />
    </Style>

    <!-- Private-tab segment: dim by default, signal-green when the Private tab is selected. -->
    <Style TargetType="Button" x:Key="PrivateTabButton" BasedOn="{StaticResource TabButton}">
        <Style.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding IsPrivateSelected}" Value="True">
                <Setter Property="TextColor" Value="{StaticResource TpBgVoid}" />
                <Setter Property="BackgroundColor" Value="{StaticResource TpSignal}" />
                <Setter Property="BorderColor" Value="{StaticResource TpSignal}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Public-tab segment: dim by default, signal-green when the Public tab is selected. -->
    <Style TargetType="Button" x:Key="PublicTabButton" BasedOn="{StaticResource TabButton}">
        <Style.Triggers>
            <DataTrigger TargetType="Button" Binding="{Binding IsPublicSelected}" Value="True">
                <Setter Property="TextColor" Value="{StaticResource TpBgVoid}" />
                <Setter Property="BackgroundColor" Value="{StaticResource TpSignal}" />
                <Setter Property="BorderColor" Value="{StaticResource TpSignal}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Playfield row name. -->
    <Style TargetType="Label" x:Key="LocationItemName">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Small uppercase PUBLIC/PRIVATE badge — base + colored variants. -->
    <Style TargetType="Label" x:Key="LocationBadge">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="HorizontalOptions" Value="End" />
    </Style>

    <Style TargetType="Label" x:Key="LocationBadgePublic" BasedOn="{StaticResource LocationBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>

    <Style TargetType="Label" x:Key="LocationBadgePrivate" BasedOn="{StaticResource LocationBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
    </Style>

    <!-- Framed, filled public-search input (mirrors the settings entry). -->
    <Style TargetType="Entry" x:Key="LocationSearchField" BasedOn="{StaticResource SettingsEntry}" />

    <!-- Destructive swipe action revealed on a Private-list row: hunter-red fill. SwipeItem (a MenuItem)
         has no TextColor property, so its glyph/text is rendered light by the platform against this
         hunter-red background; the color token lives here, never inline on the page. -->
    <Style TargetType="SwipeItem" x:Key="DeleteSwipeItem">
        <Setter Property="BackgroundColor" Value="{StaticResource TpHunter}" />
    </Style>

    <!-- ============================================================= -->
    <!-- Create playfield — form fields, visibility toggle, area        -->
    <!-- indicator, and the create / area-editor action buttons.        -->
    <!-- All reuse the Tp* tokens; the pages carry no literals.          -->
    <!-- ============================================================= -->

    <!-- Circular "+" action on the Private tab that opens the create page. Signal-green filled,
         void glyph — a floating action anchored bottom-right over the list. -->
    <Style TargetType="Button" x:Key="PlayfieldsAddButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="CharacterSpacing" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="60" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions" Value="End" />
        <Setter Property="Shadow" Value="{StaticResource SignalGlow}" />
    </Style>

    <!-- Playfield-name entry (mirrors the settings entry). -->
    <Style TargetType="Entry" x:Key="CreateNameEntry" BasedOn="{StaticResource SettingsEntry}" />

    <!-- Public/Private toggle + its flanking segment labels (reuse the language-toggle look). -->
    <Style TargetType="Switch" x:Key="VisibilityToggle" BasedOn="{StaticResource LanguageToggle}" />
    <Style TargetType="Label" x:Key="VisibilitySegmentLabel" BasedOn="{StaticResource LanguageSegmentLabel}" />

    <!-- Dim hint explaining the name pattern that unlocks the public option. -->
    <Style TargetType="Label" x:Key="CreateHint" BasedOn="{StaticResource SettingsStatusHint}" />

    <!-- "Area defined" (signal-green) / "no area" (ghost) indicator states. -->
    <Style TargetType="Label" x:Key="CreateAreaDefined" BasedOn="{StaticResource SettingsFieldLabel}">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>
    <Style TargetType="Label" x:Key="CreateAreaNone" BasedOn="{StaticResource SettingsFieldLabel}">
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
    </Style>

    <!-- Create-form action buttons (full-size CTAs). -->
    <Style TargetType="Button" x:Key="DefineAreaButton" BasedOn="{StaticResource OutlineButton}" />
    <Style TargetType="Button" x:Key="CreateSaveButton" BasedOn="{StaticResource PrimaryButton}" />
    <Style TargetType="Button" x:Key="CreateCancelButton" BasedOn="{StaticResource OutlineButton}" />

    <!-- Compact action buttons overlaid on the area-editor map. Smaller than the full-size CTAs so
         they sit over the map; colors/variants inherit from the shared button styles. -->
    <Style TargetType="Button" x:Key="MapActionButtonBase">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>
    <Style TargetType="Button" x:Key="MapActionSave" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>
    <Style TargetType="Button" x:Key="MapActionCancel" BasedOn="{StaticResource OutlineButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>
    <Style TargetType="Button" x:Key="MapActionTrash" BasedOn="{StaticResource HunterButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>
    <!-- Clear-all action in the editor's top overlay (removes every vertex at once). -->
    <Style TargetType="Button" x:Key="MapActionClear" BasedOn="{StaticResource OutlineButton}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinimumHeightRequest" Value="40" />
    </Style>

    <!-- HUD hint line for the area editor, over the map. -->
    <Style TargetType="Label" x:Key="MapHint" BasedOn="{StaticResource HudLabel}">
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
    </Style>

    <!-- ============================================================= -->
    <!-- Game lobby — pass code + share, settings selectors, the        -->
    <!-- participants list (role / ready badges), and the start/ready    -->
    <!-- actions. All reuse the Tp* tokens; the page carries no literals. -->
    <!-- ============================================================= -->

    <!-- Big signal-green pass-code readout (display face). -->
    <Style TargetType="Label" x:Key="LobbyPassCode">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="CharacterSpacing" Value="8" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Compact outline Share button next to the pass code. -->
    <Style TargetType="Button" x:Key="LobbyShareButton" BasedOn="{StaticResource OutlineButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>

    <!-- Framed, filled settings picker; owner-editable, and dimmed (read-only look) when disabled. -->
    <Style TargetType="Picker" x:Key="LobbySettingPicker">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="TitleColor" Value="{StaticResource TpTextGhost}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource TpTextSoft}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Each operative is a rounded card carrying a role-tinted frame, so the list reads as a stack of
         dossiers rather than undivided rows. Hunter rows swap the whole frame onto the hunter axis. -->
    <Style TargetType="Border" x:Key="LobbyParticipantCard">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="Stroke" Value="{StaticResource TpSignalEdgeBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="12,12,14,12" />
        <Style.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsHunter}" Value="True">
                <Setter Property="Stroke" Value="{StaticResource TpHunterEdgeBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Role accent stripe down the card's left edge — green for prey, red for hunter. Rounded on its
         own rather than relying on the card clipping it, so it renders identically on every platform. -->
    <Style TargetType="BoxView" x:Key="LobbyRoleStripe">
        <Setter Property="Color" Value="{StaticResource TpSignal}" />
        <Setter Property="WidthRequest" Value="4" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Style.Triggers>
            <DataTrigger TargetType="BoxView" Binding="{Binding IsHunter}" Value="True">
                <Setter Property="Color" Value="{StaticResource TpHunter}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Badge chips: a pill frame (Border) wrapping a small uppercase label. The frame carries the
         role's edge + wash; the label carries the role's text color. -->
    <Style TargetType="Border" x:Key="LobbyBadgeFrame">
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 9" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style TargetType="Border" x:Key="LobbyBadgeHunterFrame" BasedOn="{StaticResource LobbyBadgeFrame}">
        <Setter Property="Stroke" Value="{StaticResource TpHunterEdgeBrush}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpHunterWash}" />
    </Style>
    <Style TargetType="Border" x:Key="LobbyBadgePreyFrame" BasedOn="{StaticResource LobbyBadgeFrame}">
        <Setter Property="Stroke" Value="{StaticResource TpSignalEdgeBrush}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpSignalWash}" />
    </Style>
    <Style TargetType="Border" x:Key="LobbyBadgeOwnerFrame" BasedOn="{StaticResource LobbyBadgeFrame}">
        <Setter Property="Stroke" Value="{StaticResource TpCautionEdgeBrush}" />
        <Setter Property="BackgroundColor" Value="{StaticResource TpCautionWash}" />
    </Style>
    <!-- "YOU" is an identity marker, not a role — outline only, no fill, so it stays quieter. -->
    <Style TargetType="Border" x:Key="LobbyBadgeYouFrame" BasedOn="{StaticResource LobbyBadgeFrame}">
        <Setter Property="Stroke" Value="{StaticResource TpSignalEdgeBrush}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <!-- Readiness lamp: unlit (ghost outline) until the operative stands by, then it lights up on the
         signal axis. One chip with two states rather than two chips, so the row never reflows. -->
    <Style TargetType="Border" x:Key="LobbyBadgeReadyFrame" BasedOn="{StaticResource LobbyBadgeFrame}">
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Style.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsReady}" Value="True">
                <Setter Property="Stroke" Value="{StaticResource TpSignalEdgeBrush}" />
                <Setter Property="BackgroundColor" Value="{StaticResource TpSignalWashLit}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="BoxView" x:Key="LobbyReadyLamp">
        <Setter Property="Color" Value="{StaticResource TpTextGhost}" />
        <Setter Property="WidthRequest" Value="6" />
        <Setter Property="HeightRequest" Value="6" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Style.Triggers>
            <DataTrigger TargetType="BoxView" Binding="{Binding IsReady}" Value="True">
                <Setter Property="Color" Value="{StaticResource TpSignal}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Small uppercase badge text — base + per-role colored variants. -->
    <Style TargetType="Label" x:Key="LobbyBadge">
        <Setter Property="FontFamily" Value="{StaticResource TpBodyFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="LobbyRoleHunter" BasedOn="{StaticResource LobbyBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpHunter}" />
    </Style>
    <Style TargetType="Label" x:Key="LobbyRolePrey" BasedOn="{StaticResource LobbyBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>
    <Style TargetType="Label" x:Key="LobbyRoleOwner" BasedOn="{StaticResource LobbyBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpCaution}" />
    </Style>
    <Style TargetType="Label" x:Key="LobbyBadgeYou" BasedOn="{StaticResource LobbyBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpSignalDim}" />
    </Style>
    <Style TargetType="Label" x:Key="LobbyReadyBadge" BasedOn="{StaticResource LobbyBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
        <Style.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding IsReady}" Value="True">
                <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================= -->
    <!-- Playfield-selection modal — the selectable row highlight.      -->
    <!-- Rows reuse the list page's name + badge styles; only the       -->
    <!-- selected-row frame is new. Reuses the Tp* tokens.              -->
    <!-- ============================================================= -->

    <!-- Selectable row frame: hairline surface by default, signal-green highlight when IsSelected. -->
    <Style TargetType="Border" x:Key="SelectRow">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="Padding" Value="14,12" />
        <Style.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface2}" />
                <Setter Property="Stroke" Value="{StaticResource TpSignalBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================= -->
    <!-- Start game (config page) — the tappable playfield row plus its -->
    <!-- selected-name / choose-one prompt / change-hint labels. The    -->
    <!-- five option selectors reuse the lobby's LobbySettingPicker.     -->
    <!-- All reuse the Tp* tokens; the page carries no literals.         -->
    <!-- ============================================================= -->

    <!-- Tappable framed playfield row (reuses the selectable-row frame look). -->
    <Style TargetType="Border" x:Key="StartGamePlayfieldRow" BasedOn="{StaticResource SelectRow}" />

    <!-- Dim choose-one prompt shown in the row until a playfield is selected. -->
    <Style TargetType="Label" x:Key="StartGamePlayfieldPrompt" BasedOn="{StaticResource LocationItemName}">
        <Setter Property="TextColor" Value="{StaticResource TpTextGhost}" />
    </Style>

    <!-- Small signal-green CHANGE affordance on the right of the row. -->
    <Style TargetType="Label" x:Key="StartGamePlayfieldChange" BasedOn="{StaticResource LocationBadge}">
        <Setter Property="TextColor" Value="{StaticResource TpSignal}" />
    </Style>

    <!-- ============================================================= -->
    <!-- Join game — the sign-in prompt, the 4-digit numeric join-code  -->
    <!-- field, and the result/error state messages. All reuse the Tp*  -->
    <!-- tokens; the page carries no literals.                          -->
    <!-- ============================================================= -->

    <!-- Centered dim prompt shown while signed out, above the sign-in action. -->
    <Style TargetType="Label" x:Key="JoinSignInPrompt" BasedOn="{StaticResource TacticalBody}" />

    <!-- Large, centered, wide-spaced numeric join-code field (mirrors the settings entry look). -->
    <Style TargetType="Entry" x:Key="JoinCodeEntry" BasedOn="{StaticResource SettingsEntry}">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="CharacterSpacing" Value="8" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Amber result/error message under the code field (reuses the shared alert style). -->
    <Style TargetType="Label" x:Key="JoinStateMessage" BasedOn="{StaticResource AlertLabel}" />

    <!-- ============================================================= -->
    <!-- Passcode entry control (reusable OTP-style digit boxes). Named  -->
    <!-- neutrally so the control is not Join-specific. A single hidden  -->
    <!-- Entry captures input; the boxes below show one digit each and   -->
    <!-- the next box to fill is highlighted with a signal-green stroke. -->
    <!-- ============================================================= -->

    <!-- Horizontal row that lays out the digit boxes, centered. -->
    <Style TargetType="HorizontalStackLayout" x:Key="PasscodeBoxRow">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- A single digit box (surface fill, soft line stroke). Mirrors the JoinCodeEntry look. -->
    <Style TargetType="Border" x:Key="PasscodeBox">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface}" />
        <Setter Property="Stroke" Value="{StaticResource TpLineBrush}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="64" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- The active / next-to-fill box: signal-green stroke over a raised surface. -->
    <Style TargetType="Border" x:Key="PasscodeBoxActive" BasedOn="{StaticResource PasscodeBox}">
        <Setter Property="BackgroundColor" Value="{StaticResource TpBgSurface2}" />
        <Setter Property="Stroke" Value="{StaticResource TpSignalBrush}" />
    </Style>

    <!-- The large display digit centered inside each box. -->
    <Style TargetType="Label" x:Key="PasscodeBoxDigit">
        <Setter Property="FontFamily" Value="{StaticResource TpDisplayFont}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource TpText}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Invisible input-capturing Entry laid over the boxes; delivers the whole pasted
         value in one TextChanged so paste distributes across the boxes for free. -->
    <Style TargetType="Entry" x:Key="PasscodeHiddenEntry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="Transparent" />
        <Setter Property="Keyboard" Value="Numeric" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="Opacity" Value="0.01" />
    </Style>

    <!-- Full-bleed green scan beam that sweeps top→bottom over the Join backdrop every 10s. A soft
         vertical gradient band (bright signal-green core, transparent edges); the sweep and the
         between-sweep parking are driven in code-behind (see JoinGamePage). Starts hidden (Opacity 0)
         and is transparent to input so it never blocks the form beneath it. -->
    <Style TargetType="Border" x:Key="JoinLaserSweep">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="{StaticResource TpSignalBeamEdge}" />
                <GradientStop Offset="0.5" Color="{StaticResource TpSignalBeam}" />
                <GradientStop Offset="1.0" Color="{StaticResource TpSignalBeamEdge}" />
            </LinearGradientBrush>
        </Setter>
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="HeightRequest" Value="6" />
        <Setter Property="InputTransparent" Value="True" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Start" />
        <Setter Property="Opacity" Value="0" />
    </Style>

    <!-- ============================================================= -->
    <!-- Gameplay maps (hunter + prey) — full-screen overlays, the      -->
    <!-- head-start countdown, penalty warning, and busy/error regions. -->
    <!-- Shared by both role pages; the map marker colors live in the   -->
