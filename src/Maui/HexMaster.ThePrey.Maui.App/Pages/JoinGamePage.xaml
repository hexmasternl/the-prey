<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:HexMaster.ThePrey.Maui.App.Services.Localization"
             xmlns:vm="clr-namespace:HexMaster.ThePrey.Maui.App.ViewModels"
             x:Class="HexMaster.ThePrey.Maui.App.Pages.JoinGamePage"
             x:DataType="vm:JoinGameViewModel"
             Shell.NavBarIsVisible="False"
             Title="{loc:Translate Join_Title}">

    <Grid x:Name="RootGrid">

        <!-- Layer 1: void-black base -->
        <BoxView Style="{StaticResource SplashBase}" />

        <!-- Layer 2: oversized, dimmed tactical elevation map that slowly pans behind the content -->
        <Image x:Name="MapBackground"
               Source="theprey_background.png"
               Style="{StaticResource MenuMapBackground}"
               SemanticProperties.Description="{loc:Translate Join_Background_Description}" />

        <ScrollView>
            <VerticalStackLayout Spacing="24" Padding="28,44,28,28">

                <Label Text="{loc:Translate Join_Title}" Style="{StaticResource TacticalTitle}" />

                <!-- Sign-in gate: shown while signed out, drives the shared interactive login -->
                <VerticalStackLayout Spacing="16" IsVisible="{Binding IsSignedOut}">
                    <Label Text="{loc:Translate Join_SignIn_Prompt}" Style="{StaticResource JoinSignInPrompt}" />
                    <Button Text="{loc:Translate Join_SignIn_Button}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LogInCommand}" />
                </VerticalStackLayout>

                <!-- Join code entry: shown once signed in -->
                <VerticalStackLayout Spacing="16" IsVisible="{Binding IsSignedIn}">
                    <Label Text="{loc:Translate Join_Code_Label}"
                           Style="{StaticResource SettingsFieldLabel}"
                           HorizontalTextAlignment="Center" />
                    <Entry Text="{Binding Code, Mode=TwoWay}"
                           Placeholder="{loc:Translate Join_Code_Placeholder}"
                           Keyboard="Numeric"
                           MaxLength="4"
                           Style="{StaticResource JoinCodeEntry}" />

                    <Button Text="{loc:Translate Join_Button}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding JoinCommand}"
                            IsEnabled="{Binding CanJoin}" />
                </VerticalStackLayout>

                <!-- Result state messages (non-blocking; the entered code is kept) -->
                <Label Text="{loc:Translate Join_Error_InvalidCode}"
                       Style="{StaticResource JoinStateMessage}"
                       IsVisible="{Binding HasInvalidCode}" />
                <Label Text="{loc:Translate Join_Error_NotFound}"
                       Style="{StaticResource JoinStateMessage}"
                       IsVisible="{Binding HasNotFound}" />
                <Label Text="{Binding ConflictMessage}"
                       Style="{StaticResource JoinStateMessage}"
                       IsVisible="{Binding HasConflict}" />
                <Label Text="{loc:Translate Join_Error_Generic}"
                       Style="{StaticResource JoinStateMessage}"
                       IsVisible="{Binding HasError}" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Top layer: full-bleed green scan beam swept top→bottom every 10s by the code-behind. -->
        <Border x:Name="LaserSweep" Style="{StaticResource JoinLaserSweep}" />

        <!-- Busy indicator -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center" />

    </Grid>

</ContentPage>
