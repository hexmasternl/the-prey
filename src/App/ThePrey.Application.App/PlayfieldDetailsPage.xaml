<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="ThePrey.Application.App.PlayfieldDetailsPage"
             Style="{StaticResource PreyPage}">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="SaveToolbarItem"
                     IsEnabled="False"
                     Clicked="OnSaveClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20,16,20,32">

            <!-- Name -->
            <Label Text="NAME"
                   FontFamily="PTMono"
                   FontSize="11"
                   CharacterSpacing="2"
                   TextColor="{StaticResource SignalDim}"
                   Margin="0,0,0,6" />

            <Entry x:Name="NameEntry"
                   FontFamily="PTMono"
                   FontSize="15"
                   TextColor="{StaticResource TextPrimary}"
                   BackgroundColor="{StaticResource Surface}"
                   PlaceholderColor="{StaticResource TextGhost}"
                   Margin="0,0,0,4"
                   TextChanged="OnNameTextChanged"
                   Unfocused="OnNameUnfocused" />

            <Label x:Name="NameValidationLabel"
                   IsVisible="False"
                   FontFamily="PTMono"
                   FontSize="12"
                   TextColor="{StaticResource Hunter}"
                   Margin="0,0,0,16" />

            <!-- Visibility toggle -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0"
                       x:Name="VisibilityLabel"
                       FontFamily="PTMono"
                       FontSize="11"
                       CharacterSpacing="2"
                       TextColor="{StaticResource SignalDim}"
                       VerticalOptions="Center" />
                <Switch x:Name="PublicSwitch"
                        Grid.Column="1"
                        OnColor="{StaticResource Signal}"
                        ThumbColor="{StaticResource Void}"
                        IsToggled="False" />
            </Grid>

            <!-- Area section -->
            <Label x:Name="AreaLabel"
                   FontFamily="PTMono"
                   FontSize="11"
                   CharacterSpacing="2"
                   TextColor="{StaticResource SignalDim}"
                   Margin="0,0,0,6" />

            <maps:Map x:Name="MiniMap"
                      HeightRequest="200"
                      IsScrollEnabled="False"
                      IsZoomEnabled="False"
                      Margin="0,0,0,4" />

            <Label x:Name="LocationNoticeLabel"
                   IsVisible="False"
                   FontFamily="PTMono"
                   FontSize="12"
                   TextColor="{StaticResource TextSoft}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,12" />

            <Button x:Name="SetAreaButton"
                    Style="{StaticResource BtnGhost}"
                    Clicked="OnSetAreaClicked"
                    Margin="0,0,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
